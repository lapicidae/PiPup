<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_nav_advanced"
        android:textColor="@color/colorOnSurface"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        android:textAlignment="viewStart"
        android:gravity="start"/>

    <!-- Stability -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_stability" android:textColor="@color/colorOnSurfaceVariant" android:layout_marginTop="20dp" android:textAlignment="viewStart" android:gravity="start"/>
    <LinearLayout
        android:id="@+id/container_energy_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:focusable="true"
        android:clickable="true"
        android:background="@drawable/focus_background"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/energy_optimization_title"
                android:textColor="@color/colorOnSurface"
                android:textSize="16sp"
                android:textAlignment="viewStart"
                android:gravity="start"/>
            <TextView
                android:id="@+id/text_energy_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/energy_status_optimized"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:textAlignment="viewStart"
                android:gravity="start"/>
        </LinearLayout>
        <View
            android:id="@+id/view_energy_indicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/color_preset_circle"
            android:backgroundTint="@color/status_red"/>
    </LinearLayout>

    <!-- Migration -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_migration" android:textColor="@color/colorOnSurfaceVariant" android:layout_marginTop="32dp" android:textAlignment="viewStart" android:gravity="start"/>
    <Button
        android:id="@+id/btn_import_network"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/settings_import_network"
        android:focusable="true"
        android:background="@drawable/focus_background"
        android:padding="12dp"
        android:gravity="start|center_vertical"
        android:textAlignment="viewStart"
        android:textAllCaps="false"
        android:textColor="@color/colorOnSurface"/>

    <!-- Tools -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_tools"
        android:textColor="@color/colorOnSurfaceVariant"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="15dp"
        android:textAlignment="viewStart"
        android:gravity="start" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/text_media_timeout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_media_timeout"
            android:textColor="@color/colorOnSurfaceVariant"
            android:layout_marginStart="12dp" />

        <TextView
            android:id="@+id/text_media_timeout_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/colorOnSurfaceVariant"
            tools:text="10s" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekbar_media_timeout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="30"
        android:focusable="true"
        android:background="@drawable/focus_background"
        android:padding="12dp"
        android:thumbTint="@color/tv_thumb_selector"
        android:progressTint="@color/tv_thumb_selector"
        android:progressBackgroundTint="@color/tv_track_selector"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:id="@+id/container_pre_warm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:focusable="true"
        android:background="@drawable/focus_background"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_pre_warm_webview"
                android:textColor="@color/colorOnSurface"
                android:textSize="16sp"
                android:textAlignment="viewStart"
                android:gravity="start"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_pre_warm_webview_desc"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:textAlignment="viewStart"
                android:gravity="start"/>
        </LinearLayout>
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_pre_warm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:clickable="false"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/container_advanced"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:focusable="true"
        android:background="@drawable/focus_background"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_advanced_mode"
                android:textColor="@color/colorOnSurface"
                android:textSize="16sp"
                android:textAlignment="viewStart"
                android:gravity="start"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_advanced_mode_desc"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:textAlignment="viewStart"
                android:gravity="start"/>
        </LinearLayout>
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_advanced"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:clickable="false"/>
    </LinearLayout>

    <!-- Danger Zone -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_danger_zone" android:textColor="@color/status_red" android:layout_marginTop="48dp" android:textStyle="bold" android:textAlignment="viewStart" android:gravity="start"/>
    <Button
        android:id="@+id/btn_reset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/settings_reset_settings"
        android:textColor="@color/colorOnSurface"
        android:focusable="true"
        android:background="@drawable/focus_background"
        android:padding="12dp"
        android:gravity="start|center_vertical"
        android:textAlignment="viewStart"
        android:textAllCaps="false"/>

</LinearLayout>
