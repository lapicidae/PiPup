<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_nav_text"
        android:textColor="@color/colorOnSurface"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <!-- Title -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_title_color" android:textColor="@color/colorOnSurfaceVariant"/>
    <Spinner android:id="@+id/spinner_title_color" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:focusable="true" android:background="@drawable/focus_background" android:padding="8dp"/>
    <Button android:id="@+id/btn_edit_title_hex" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_title_color" tools:text="#FFFFFF" android:visibility="gone" style="@android:style/Widget.DeviceDefault.Button.Toggle" android:focusable="true" android:gravity="start|center_vertical" android:paddingStart="12dp" android:paddingEnd="12dp" android:textColor="@color/colorOnSurface"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_title_size"
            android:textColor="@color/colorOnSurfaceVariant" />
        <TextView
            android:id="@+id/text_title_size_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/colorOnSurfaceVariant"
            android:visibility="gone"
            tools:text="32 / 64" />
    </LinearLayout>
    <SeekBar android:id="@+id/seekbar_title_size" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="64" android:focusable="true" android:background="@drawable/focus_background" android:padding="12dp" android:thumbTint="@color/tv_thumb_selector" android:progressTint="@color/tv_thumb_selector" android:progressBackgroundTint="@color/tv_track_selector"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_title_alignment" android:textColor="@color/colorOnSurfaceVariant" android:layout_marginTop="24dp"/>
    <Spinner android:id="@+id/spinner_title_alignment" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" android:focusable="true" android:background="@drawable/focus_background" android:padding="8dp"/>

    <!-- Message -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_message_color" android:textColor="@color/colorOnSurfaceVariant" android:layout_marginTop="24dp"/>
    <Spinner android:id="@+id/spinner_message_color" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:focusable="true" android:background="@drawable/focus_background" android:padding="8dp"/>
    <Button android:id="@+id/btn_edit_message_hex" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_message_color" tools:text="#F4EFF4" android:visibility="gone" style="@android:style/Widget.DeviceDefault.Button.Toggle" android:focusable="true" android:gravity="start|center_vertical" android:paddingStart="12dp" android:paddingEnd="12dp" android:textColor="@color/colorOnSurface"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_message_size"
            android:textColor="@color/colorOnSurfaceVariant" />
        <TextView
            android:id="@+id/text_message_size_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/colorOnSurfaceVariant"
            android:visibility="gone"
            tools:text="24 / 48" />
    </LinearLayout>
    <SeekBar android:id="@+id/seekbar_message_size" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="48" android:focusable="true" android:background="@drawable/focus_background" android:padding="12dp" android:thumbTint="@color/tv_thumb_selector" android:progressTint="@color/tv_thumb_selector" android:progressBackgroundTint="@color/tv_track_selector"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_message_alignment" android:textColor="@color/colorOnSurfaceVariant" android:layout_marginTop="24dp"/>
    <Spinner android:id="@+id/spinner_message_alignment" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" android:focusable="true" android:background="@drawable/focus_background" android:padding="8dp"/>

</LinearLayout>
