<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_section_text"
        android:textColor="#E8EAED"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_title_color" android:textColor="#9AA0A6"/>
    <Spinner android:id="@+id/spinner_title_color" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:focusable="true" android:background="@drawable/focus_background" android:padding="8dp"/>
    <Button android:id="@+id/btn_edit_title_hex" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_title_color" tools:text="#FFFFFF" android:visibility="gone" style="@android:style/Widget.DeviceDefault.Button.Toggle" android:focusable="true" android:gravity="start|center_vertical" android:paddingStart="12dp" android:paddingEnd="12dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_title_size" android:textColor="#9AA0A6" android:layout_marginTop="16dp"/>
    <SeekBar android:id="@+id/seekbar_title_size" android:layout_width="match_parent" android:layout_height="wrap_content" android:min="10" android:max="60" android:focusable="true" android:background="@drawable/focus_background" android:padding="12dp" android:thumbTint="@color/tv_thumb_selector" android:progressTint="@color/tv_thumb_selector" android:progressBackgroundTint="@color/tv_track_selector"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_title_alignment" android:textColor="#9AA0A6" android:layout_marginTop="16dp"/>
    <Spinner android:id="@+id/spinner_title_alignment" android:layout_width="match_parent" android:layout_height="wrap_content" android:focusable="true" android:background="@drawable/focus_background" android:padding="8dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_message_color" android:textColor="#9AA0A6" android:layout_marginTop="32dp"/>
    <Spinner android:id="@+id/spinner_message_color" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:focusable="true" android:background="@drawable/focus_background" android:padding="8dp"/>
    <Button android:id="@+id/btn_edit_message_hex" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_message_color" tools:text="#FFFFFF" android:visibility="gone" style="@android:style/Widget.DeviceDefault.Button.Toggle" android:focusable="true" android:gravity="start|center_vertical" android:paddingStart="12dp" android:paddingEnd="12dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_message_size" android:textColor="#9AA0A6" android:layout_marginTop="16dp"/>
    <SeekBar android:id="@+id/seekbar_message_size" android:layout_width="match_parent" android:layout_height="wrap_content" android:min="10" android:max="50" android:focusable="true" android:background="@drawable/focus_background" android:padding="12dp" android:thumbTint="@color/tv_thumb_selector" android:progressTint="@color/tv_thumb_selector" android:progressBackgroundTint="@color/tv_track_selector"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_message_alignment" android:textColor="#9AA0A6" android:layout_marginTop="16dp"/>
    <Spinner android:id="@+id/spinner_message_alignment" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:focusable="true" android:background="@drawable/focus_background" android:padding="8dp"/>

</LinearLayout>
