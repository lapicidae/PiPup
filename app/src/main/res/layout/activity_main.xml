<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools"
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:layout_gravity="center"
        android:id="@+id/mainLayout">

    <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintDimensionRatio="16:9"
            android:id="@+id/imageViewLogo"
            android:importantForAccessibility="no"
            android:scaleType="fitCenter"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:src="@drawable/ic_banner_clear"
            app:tint="@color/main_logo_tint" />

    <TextView
            android:alpha="0.9"
            android:id="@+id/textViewConnection"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_width="wrap_content"
            android:text="@string/server_running"
            android:textColor="@color/main_on_background"
            android:textSize="21sp"
            android:textStyle="normal"
            app:layout_constraintEnd_toEndOf="@+id/imageViewLogo"
            app:layout_constraintStart_toStartOf="@+id/imageViewLogo"
            app:layout_constraintTop_toBottomOf="@+id/imageViewLogo"/>

    <TextView
            android:text="@string/more_information"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:linksClickable="true"
            android:id="@+id/textViewInfo"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="24dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:textColor="@color/main_on_background"/>

    <TextView
            android:text="@string/settings_no"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/textViewServerAddress"
            tools:text="192.168.1.100:7979"
            app:layout_constraintEnd_toEndOf="@+id/textViewConnection"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@+id/textViewConnection"
            app:layout_constraintStart_toStartOf="@+id/textViewConnection"
            android:textColor="@color/main_on_background"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textDirection="ltr"/>

    <TextView
        android:alpha="0.7"
        android:id="@+id/textViewVersion"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_width="wrap_content"
        android:text="@string/version_number"
        android:textColor="@color/main_on_background"
        android:textStyle="italic"
        android:textDirection="ltr"
        app:layout_constraintEnd_toEndOf="@+id/textViewServerAddress"
        app:layout_constraintStart_toStartOf="@+id/textViewServerAddress"
        app:layout_constraintTop_toBottomOf="@+id/textViewServerAddress" />

    <TextView
        android:id="@+id/textViewUpdateAvailable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/settings_update_found_indicator"
        android:textColor="@color/status_red"
        android:textStyle="bold"
        android:visibility="gone"
        android:focusable="false"
        android:clickable="false"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@+id/textViewVersion"
        app:layout_constraintStart_toStartOf="@+id/textViewVersion"
        app:layout_constraintEnd_toEndOf="@+id/textViewVersion"
        tools:visibility="visible"/>

    <ImageButton
            android:id="@+id/btn_open_settings"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            android:scaleType="fitCenter"
            android:padding="12dp"
            android:focusable="true"
            android:contentDescription="@string/settings_open"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/main_on_background"/>

    <TextView
        android:id="@+id/textViewCredits"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginBottom="15dp"
        android:text="@string/translator_credits"
        android:textColor="@color/main_on_background"
        android:textSize="11sp"
        android:alpha="0.6"
        android:rotation="-90"
        android:transformPivotX="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="Übersetzt von: [Name]"/>

</androidx.constraintlayout.widget.ConstraintLayout>
