# ====================================================================
# Android Project GitIgnore
# ====================================================================

### Android & Build Artifacts ###
# Compiled Java class files
*.class

# Generated Android files and folders
*.dex
bin/
gen/
out/
**/build/
captures/
.navigation/
.externalNativeBuild/
.cxx/
obj/

# Android Studio Profiling and Trace files
*.hprof

# Built application packages (App Bundles and APKs)
*.apk
*.ap_
*.aab

### Signing & Security ###
# Private keystores and signing configurations must stay local
*.jks
*.keystore
*.pk8
*.p12
.signing/

### Gradle ###
# Gradle local cache and settings
.gradle/
gradle-app.setting
.gradletasknamecache

# Ensure the Gradle Wrapper is tracked for build consistency across environments
!gradle-wrapper.jar
!/gradle/wrapper/gradle-wrapper.jar
!gradle-wrapper.properties

### IDE Specific - Android Studio / IntelliJ / VS Code ###
# Ignore the entire .idea folder by default
.idea/

# Whitelist shared project settings for team collaboration
!.idea/codeStyles/
!.idea/dictionaries/
!.idea/compiler.xml
!.idea/vcs.xml
!.idea/runConfigurations/
!.idea/modules.xml

# Blacklist user-specific and temporary IDE files inside .idea
.idea/workspace.xml
.idea/tasks.xml
.idea/assetWizardSettings.xml
.idea/caches/
.idea/libraries/

# Project-specific IDE settings (individual preferences should not be tracked)
*.iml
*.ipr
*.iws

# Editor temporary, backup, and workspace files
*.swp
*~
*.code-workspace
.vscode/

### Local Configuration ###
# Contains local SDK paths and machine-specific configs
local.properties

### Plugins & Third-Party Tools ###
# Fastlane reports and generated assets (Keep Fastfile and Appfile tracked!)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/

# Crashlytics and Fabric configuration files
com_crashlytics_export_strings.xml
crashlytics.properties
crashlytics-build.properties
fabric.properties

# Freeline build accelerator
freeline.py
freeline/
freeline_project_description.json

# Continuous Integration & Misc plugins
.jenkins-external
atlassian-ide-plugin.xml
.idea_modules/

### Operating System Metadata ###
# macOS metadata and thumbnails
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.AppleDB
.AppleDesktop
.apdisk
.Spotlight-V100
.Trashes
Network\ Trash\ Folder
Temporary\ Items

# Windows metadata, caches, and installer files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux / KDE / Generic
.fuse_hidden*
.directory
.Trash-*
*.kate-swp

### Legacy & Compatibility ###
# Eclipse project files
.classpath
.project
.cproject
.settings/
proguard/

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Java Package Files
*.war
*.ear

# Virtual machine crash logs
hs_err_pid*
